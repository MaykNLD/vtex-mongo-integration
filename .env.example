# ─────────────────────────────────────────────────────
# VTEX-Mongo Integration — Environment Variables
# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Server
PORT=3000

# MongoDB connection URI
MONGO_URI=mongodb://localhost:27017/vtex-gateway

# VTEX API Credentials
# Get from your VTEX admin panel: Account > API Keys
VTEX_APP_KEY=your_vtex_app_key_here
VTEX_APP_TOKEN=your_vtex_app_token_here
VTEX_ACCOUNT_NAME=your_vtex_account_name_here
